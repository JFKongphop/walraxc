{
  "name": "walraxc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["backend", "packages/*"],
  "scripts": {
    "setup": "cd backend && bun install && cd .. && bun install && node build.cjs",
    "install:all": "bun install",
    "install:backend": "cd backend && bun install",
    "build:cli": "node build.cjs",
    "start:server": "cd backend && bun run src/bin/ws-server.ts",
    "start:client": "cd backend && bun run src/bin/ws-client.ts",
    "example": "cd backend && bun run examples/agent-example.ts",
    "audit": "./dist/walraxc run --file example.move"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.13.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.5",
    "openai": "^4.87.3",
    "viem": "^2.23.5",
    "zod": "^3.24.3",
    "commander": "^14.0.3",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.14.0",
    "typescript": "^5.7.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.0.0"
  }
}
